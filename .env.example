# ============================================================
# PiperFlow CRM — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis com prefixo NEXT_PUBLIC_ são embutidas no bundle do
# navegador — NUNCA coloque segredos nelas.
# ============================================================

# --- Supabase (Dashboard > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Chave secreta (service role) — SÓ usada no servidor
# (Server Actions / Route Handlers). Nunca importar em código cliente.
SUPABASE_SECRET_KEY=sb_secret_xxx

# --- Stripe (Dashboard > Developers > API keys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Assinatura do webhook (Dashboard > Developers > Webhooks,
# ou `stripe listen` no desenvolvimento local)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (e-mail transacional: convites de equipe) ---
RESEND_API_KEY=re_xxx

# --- App ---
# URL pública do site (links de convite, redirects do Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
